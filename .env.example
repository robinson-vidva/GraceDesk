# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
DJANGO_SETTINGS_MODULE=gracedesk.settings.development
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (production only — dev uses SQLite)
DATABASE_URL=postgres://user:password@host:5432/gracedesk

# Brevo Email
BREVO_API_KEY=your-brevo-api-key
BREVO_WEBHOOK_TOKEN=your-webhook-token
DEFAULT_FROM_EMAIL=noreply@gracedesk.org

# Field Encryption
FIELD_ENCRYPTION_KEY=your-encryption-key
